# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
.cabinet.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data: pure local runtime state — never tracked. Seed content lives in resources/.
/data/

# old data backup
/old-data/
# local data backups (e.g. created before a migration) — never tracked
/data-backup-*/
/data copy/

# claude code — ignore everything except project-level slash commands
.claude/*
!.claude/commands
.claude/commands/*
!.claude/commands/*.md

# cabinetai CLI
cabinetai/dist/
cabinetai/node_modules/

# local install config (per-machine dataDir)
.cabinet-install.json

# per-machine cabinet/repo runtime metadata (written when dogfooding Cabinet on
# this repo — .repo.yaml hardcodes a local absolute path; never track these)
.cabinet-meta
.repo.yaml

# skills lock (per-machine; runtime-managed)
skills-lock.json

# installed skills bundles (per-machine; managed by Settings -> Skills)
# Use the cascade pattern to allow repo-shipped bundles (cabinet-root origin)
.agents/skills-stats.json
.agents/skills/*
!.agents/skills/testing-and-reviewing
.agents/skills/testing-and-reviewing/*
!.agents/skills/testing-and-reviewing/SKILL.md

# latex.js static assets copied from node_modules by postinstall
/public/latex-js/
